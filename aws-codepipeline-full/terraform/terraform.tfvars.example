region        = "ap-southeast-1"
project_name  = "cicd-evo"
instance_type = "t3.micro"

vpc_id = "vpc-036b914bdf14d227e"

# PUBLIC subnets (route 0.0.0.0/0 → IGW). ≥2 AZs for the ALB.
subnet_ids = [
  "subnet-00cc2f1df9ce195ab",
  "subnet-00cd9499101129734",
]

# PRIVATE subnets (route 0.0.0.0/0 → NAT GW) for the integration-test CodeBuild ENI.
# CodeBuild ENI gets no public IP, so this subnet must have NAT egress.
# Optional: omit and the integration test will use subnet_ids (only works if those have NAT routes).
codebuild_subnet_ids = [
  "subnet-0c51b6b97f99b69ed",
  "subnet-095f2eb89045eb289",
]

# GitHub repo to pull source from. Must already exist on GitHub.
# After `terraform apply`, manually authorize the connection in AWS Console.
github_repo = "eveningcafe/cicd-evo"
branch_name = "main"

tags = {
  Owner = "your-name"
}
