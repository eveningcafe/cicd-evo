# A PUBLIC subnet (route table → IGW) in your VPC.
# Find one with:
#   aws ec2 describe-route-tables --region <region> \
#     --query 'RouteTables[?Routes[?GatewayId!=null && starts_with(GatewayId,`igw-`)]].Associations[].SubnetId'
